# ============================================
# Python 项目 .gitignore
# ============================================

# Python 编译产物
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/
*.whl

# 虚拟环境
.venv/
venv/
env/
env.bak/
venv.bak/

# 工具链缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
coverage.xml
htmlcov/
.tox/
noxfile.py

# ============================================
# 项目数据文件
# ============================================

# 向量数据库（体积大，可重新生成）
data/vector_db/
chroma_db/
chroma/

# 原始数据（可选，根据实际情况）
data/raw/

# 会话数据（运行时生成）
data/sessions/
sessions/

# 日志文件
*.log
logs/
data/logs/

# 同步日志
data/sync.log

# ============================================
# IDE 和编辑器
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# Jupyter
.ipynb_checkpoints

# ============================================
# 操作系统
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# 环境变量（包含敏感信息）
# ============================================
.env
.env.local
.env.production
!.env.example

# ============================================
# 临时文件
# ============================================
*.tmp
*.bak
*.cache
*.pid
output/
temp/
*.pid

# ============================================
# Docker（可选）
# ============================================
docker-compose.override.yml

# ============================================
# AI 工具生成（根据实际需要）
# ============================================
.qwen/settings.json

# 测试数据（运行时生成）
tests/test_pipeline/data/

