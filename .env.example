# 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改
# 所有配置项都有默认值，此文件仅用于说明和自定义覆盖

# ============ 应用配置 ============
# 应用名称和版本
APP_NAME=qa-full-flow
APP_VERSION=0.3.0
# 调试模式（开发环境设为 true）
DEBUG=false

# ============ API服务配置 ============
API_HOST=0.0.0.0
API_PORT=8000

# ============ Embedding模型配置 ============
# 模型名称（首次运行会自动下载）
EMBEDDING_MODEL=BAAI/bge-m3
# 运行设备: cpu 或 cuda
EMBEDDING_DEVICE=cpu

# ============ Reranker模型配置 ============
# 重排序模型
RERANKER_MODEL=BAAI/bge-reranker-large
# 运行设备: cpu 或 cuda
RERANKER_DEVICE=cpu

# ============ ChromaDB配置 ============
# 向量数据库存储路径（相对于项目根目录）
CHROMA_PATH=./data/vector_db/chroma_kb
# 集合名称
CHROMA_COLLECTION_NAME=test_knowledge

# ============ LLM配置（可选，用于AI生成测试用例） ============
# OpenAI API Key（如果不配置，系统将使用简单模板模式）
LLM_API_KEY=
# API基础URL（可替换为国内镜像或其他兼容接口）
LLM_BASE_URL=https://api.openai.com/v1
# 模型名称
LLM_MODEL=gpt-3.5-turbo
# 请求超时时间（秒）
LLM_TIMEOUT=60
# 最大重试次数
LLM_MAX_RETRIES=3

# ============ Tapd配置 ============
# Tapd 项目 Workspace ID（项目 ID，可从项目 URL 中获取）
TAPD_WORKSPACE_ID=
# Tapd API 用户名（公司管理员在 公司管理 -> 开放平台 中获取）
TAPD_API_USER=
# Tapd API 口令（公司管理员在 公司管理 -> 开放平台 中获取）
TAPD_API_PASSWORD=

# ============ JIRA配置 ============
# JIRA地址（Atlassian Cloud示例）
JIRA_URL=https://your-company.atlassian.net
# 邮箱账号
JIRA_EMAIL=your-email@company.com
# API Token（在 https://id.atlassian.com/manage-profile/security/api-tokens 创建）
JIRA_API_TOKEN=
# 项目Key（可选，为空则拉取所有项目，如：TEST、DEV）
JIRA_PROJECT_KEY=

# ============ Confluence配置 ============
# Confluence地址（Atlassian Cloud示例）
CONFLUENCE_URL=https://your-company.atlassian.net/wiki
# 邮箱账号（可与JIRA相同）
CONFLUENCE_EMAIL=your-email@company.com
# API Token（可与JIRA相同）
CONFLUENCE_API_TOKEN=

# ============ 定时同步配置 ============
# 同步间隔（小时），默认6小时
SYNC_INTERVAL_HOURS=6

# ============ HF镜像（国内加速） ============
# HuggingFace镜像地址（中国大陆用户可使用 https://hf-mirror.com）
HF_ENDPOINT=https://hf-mirror.com

# ============ 日志配置 ============
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# 日志文件路径（设置为空则只输出到控制台）
# LOG_FILE=./data/logs/app.log
# 是否使用JSON格式日志（便于日志分析工具处理）
LOG_USE_JSON=false
